// إزالة المكرر
const seen = new Set();
const uniqueSources = sources.filter(s => {
  const key = s.url.replace(/\/$/, '');
  if (seen.has(key)) return false;
  seen.add(key);
  return true;
});

async function fetchWithRetry(source, retries = 3) {
  for (let i = 0; i < retries; i++) {
    try {
      const config = {
        timeout: 60000,
        httpsAgent: agent,
        headers: source.headers || {
          'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/125.0.0.0 Safari/537.36',
          'Accept': 'application/json'
        }
      };
      
      // محاولات متعددة للـ URL (مع/بدون slash)
      try {
        return await axios.get(source.url, config);
      } catch (e) {
        // إذا فشل الرابط الأصلي، جرب نسخة بطرق مختلفة
        if (e.response?.status === 404 || e.code === 'ERR_BAD_REQUEST') {
          // المصادر ممكن تكون في مسارات مختلفة
          const altUrls = [
            source.url.endsWith('/') ? source.url.slice(0, -1) : source.url + '/',
            source.url + '/apps.json',
            source.url.replace(/\/+$/, '') + '/apps.json',
            source.url + '/index.json',
            source.url.replace(/\/+$/, '') + '/index.json',
          ];
          
          for (const altUrl of altUrls) {
            try {
              return await axios.get(altUrl, config);
            } catch (e2) {
              // تجاهل الخطأ وجرب الرابط التالي
            }
          }
        }
        throw e; // إذا فشلت كل المحاولات
      }
    } catch (e) {
      if (i === retries - 1) throw e;
      const delay = 3000 * (i + 1);
      console.log(`      ⏳ Retry ${i + 1}/${retries} in ${delay}ms...`);
      await new Promise(r => setTimeout(r, delay));
    }
  }
}

function extractApps(data) {
  if (!data) return [];
  
  // AltStore format standard
  if (data.apps && Array.isArray(data.apps)) return data.apps;
  
  // Array مباشر
  if (Array.isArray(data)) return data;
  
  // data.data.apps (مثل UnKeySign)
  if (data.data?.apps && Array.isArray(data.data.apps)) return data.data.apps;
  
  // result.data
  if (data.result?.data && Array.isArray(data.result.data)) return data.result.data;
  
  // أي key يحتوي على Array مع bundleIdentifier
  for (const key of Object.keys(data)) {
    if (Array.isArray(data[key])) {
      if (data[key].length > 0 && typeof data[key][0] === 'object') {
        if (data[key][0].bundleIdentifier || data[key][0].name || data[key][0].downloadURL) {
          return data[key];
        }
      }
      // حتى لو ما في bundleIdentifier, خذ أول array كبير
      if (data[key].length > 5) {
        return data[key];
      }
    }
  }
  
  return [];
}

async function mergeSources() {
  const appsMap = new Map();
  let totalFetched = 0;
  let successSources = 0;
  const failedSourcesList = [];
  const details = [];

  console.log('='.repeat(70));
  console.log('🔥 ADNAN COMBINED STORE - MERGE ENGINE v4');
  console.log('📦 Total sources: ' + uniqueSources.length);
  console.log('='.repeat(70) + '\n');

  for (const source of uniqueSources) {
    process.stdout.write(`[${source.name}] `);
    
    try {
      const response = await fetchWithRetry(source);
      const data = response.data;
      const appsArray = extractApps(data);

      if (appsArray.length > 0) {
        let sourceCount = 0;
        for (const app of appsArray) {
          if (!app || typeof app !== 'object') continue;
          
          // استخدام bundleIdentifier + name + developerName كمفتاح (لتجنب التكرار)
          const key = [
            app.bundleIdentifier || '',
            app.name || '',
            app.developerName || ''
          ].filter(Boolean).join('|') || `unknown-${Date.now()}-${Math.random()}`;

          if (appsMap.has(key)) {
            const existing = appsMap.get(key);
            
            // دمج النسخ
            if (app.versions && Array.isArray(app.versions)) {
              if (!existing.versions) existing.versions = [];
              const existingVersions = new Set(
                existing.versions.map(v => v.version || v.downloadURL || v.date || '')
              );
              for (const v of app.versions) {
                const vKey = v.version || v.downloadURL || v.date || '';
                if (!existingVersions.has(vKey)) {
                  existing.versions.push(v);
                  existingVersions.add(vKey);
                }
              }
            }
            
            // تعبئة الحقول الفارغة
            const fields = ['iconURL', 'subtitle', 'developerName', 'localizedDescription', 
                          'version', 'versionDate', 'downloadURL', 'size', 'tintColor', 
                          'screenshots', 'appPermissions', 'beta'];
            for (const field of fields) {
              if (!existing[field] && app[field]) existing[field] = app[field];
            }
          } else {
            appsMap.set(key, { ...app });
          }
          sourceCount++;
          totalFetched++;
        }
        successSources++;
        console.log(`✅ ${sourceCount} apps`);
        details.push({ name: source.name, status: '✅', count: sourceCount });
      } else {
        console.log('⚠️ 0 apps');
        details.push({ name: source.name, status: '⚠️', count: 0 });
      }
    } catch (e) {
      const errorMsg = e.response 
        ? `HTTP ${e.response.status} - ${e.response.statusText}` 
        : e.code || e.message.substring(0, 50);
      console.log(`❌ ${errorMsg}`);
      failedSourcesList.push(source.name);
      details.push({ name: source.name, status: '❌', error: errorMsg });
    }
  }

  const uniqueApps = Array.from(appsMap.values());

  console.log('\n' + '='.repeat(70));
  console.log('📊 FINAL RESULTS:');
  console.log(`   ✅ Sources succeeded: ${successSources}/${uniqueSources.length}`);
  console.log(`   ❌ Sources failed:    ${uniqueSources.length - successSources}`);
  console.log(`   📥 Total fetched:     ${totalFetched}`);
  console.log(`   🎯 Unique apps:       ${uniqueApps.length}`);
  console.log('='.repeat(70));

  if (failedSourcesList.length > 0) {
    console.log('\n⚠️ FAILED SOURCES:');
    failedSourcesList.forEach(s => console.log(`   • ${s}`));
  }

  console.log('\n📋 DETAILED REPORT:');
  details.forEach(d => {
    const count = d.count ? d.count.toString().padStart(6) : '     ';
    console.log(`   ${d.status} ${count}  ${d.name}${d.error ? ' (' + d.error + ')' : ''}`);
  });

  // إنشاء الملف النهائي
  const output = {
    name: "Adnan Combined Store",
    identifier: "com.adnan.combined",
    subtitle: `${uniqueApps.length} apps from ${successSources} sources`,
    description: `🔥 Auto-merged from ${successSources} AltStore sources. Updated every 6 hours.\n\n📊 ${uniqueApps.length} unique apps | ${successSources}/${uniqueSources.length} sources active\n\nIncludes: FastSign, Swaggy, CyPwn, Quantum, WuXu, QnBlackCat, OatmealDome, Crystall1ne, UTM, Provenance, Odyssey, Taurine, Bunduuk, Flycast, Vizunchik, YTLitePlus, PojavLauncher, iSH, Random, SideStore, Burrito, and more.`,
    iconURL: "https://raw.githubusercontent.com/quarksources/quarksources.github.io/master/icon.png",
    headerURL: "https://raw.githubusercontent.com/quarksources/quarksources.github.io/master/icon.png",
    website: "https://github.com/",
    tintColor: "#e74c3c",
    apps: uniqueApps,
    news: [
      {
        title: `🚀 ${uniqueApps.length} Apps Ready`,
        identifier: "store-update",
        caption: `Merged from ${successSources} sources. Updated automatically every 6 hours.`,
        date: new Date().toISOString().split('T')[0],
        tintColor: "e74c3c",
        notify: false
      }
    ]
  };

  fs.writeFileSync("apps.json", JSON.stringify(output, null, 2));

  const fileSizeMB = (fs.statSync("apps.json").size / 1024 / 1024).toFixed(2);
  console.log(`\n✅ apps.json written! (${fileSizeMB} MB)`);
  console.log(`🔗 https://raw.githubusercontent.com/El-inframundo/My-AltStore-Source/main/apps.json`);
}

mergeSources();
